#!/bin/sh
# .git/hooks/pre-push
#
# Runs local CI checks before every push.
# Install:
#   cp scripts/pre-push .git/hooks/pre-push
#   chmod +x .git/hooks/pre-push
#
# Note: this always runs check.sh in check-only mode (no --fix),
# so it will never modify your working directory on its own.
# If checks fail, run `./scripts/check.sh --fix`, review/commit
# the result, then push again.

cd "$(git rev-parse --show-toplevel)" || exit 1

echo ""
echo "pre-push: running local checks..."

if bash scripts/check.sh; then
  echo ""
  echo "pre-push: all checks passed."
  exit 0
else
  echo ""
  echo "pre-push: checks failed. Fix errors before pushing."
  echo "Tip: You can run './scripts/check.sh --fix' to automatically correct formatting issues with go.mod."
  echo "      After confirming the changes, use git add + commit, then push again."
  exit 1
fi
